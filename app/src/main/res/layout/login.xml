<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡PRIMERO, PIEDRA!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="40dp" />

        <TextView
            android:id="@+id/tvManual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="50dp"
            android:text="Manual de Supervivencia:\n\n1. Escoge tu arma (piedra, papel o tijeras)\n2. Vence a la IA a 5 victorias\n3. ¡Gana monedas!"
            android:textSize="17sp"
            android:textStyle="italic"
            android:textColor="#212121"
            android:gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Introduce tu nombre:"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0B0000"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etNombreUsuario"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:hint="Escribe aquí..."
            android:background="@android:drawable/editbox_background"
            android:padding="15dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnEntrar"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="ENTRAR"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E91E63"
            android:elevation="5dp" />

    </LinearLayout>

</FrameLayout>