<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F06292" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F48FB1" />
    </LinearLayout>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#E91E63"
        app:title="¡Primero, Piedra!"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="TOP 3 Supervivientes"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardHistorial"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#F8BBCE"
        app:cardCornerRadius="25dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMiniHistorial"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnJugar"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:layout_marginTop="24dp"
        android:textStyle="bold"
        android:text="JUGAR"
        android:backgroundTint="#E91E63"
        app:layout_constraintTop_toBottomOf="@id/cardHistorial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnHistorial"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:textStyle="bold"
        android:text="HISTORIAL"
        android:backgroundTint="#E91E63"
        app:layout_constraintTop_toBottomOf="@id/btnJugar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnConfiguracion"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:textStyle="bold"
        android:text="CONFIGURACIÓN"
        android:backgroundTint="#E91E63"
        app:layout_constraintTop_toBottomOf="@id/btnHistorial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>